---
import Base from "@/layouts/Base.astro";
import { getCollectionCTM } from "@/lib/contentParser.astro";
import { getEntryCTM } from "@/lib/contentParser.astro";
import PageHeader from "@/components/widgets/PageHeader.astro";
import { supportedLanguages } from "@/lib/utils/i18nUtils.ts";
import BlogLayout from "@/components/BlogLayout.astro";
import config from ".astro/config.generated.json";

export async function getStaticPaths() {
  const paths = await Promise.all(
    supportedLanguages.map(async (lang) => {
      const blogFolder = config.settings.blogFolder as "blog";
      const { defaultLanguage, showDefaultLangInUrl } =
        config.settings.multilingual;

      const postIndex = await getEntryCTM(
        blogFolder,
        "-index",
        lang.languageCode,
      );

      const posts = await getCollectionCTM(blogFolder, lang.languageCode);
      const blogPerPage =
        Number(config.settings.blogPagination ?? config.settings.pagination) ||
        0;
      const paths = [];

      // If draft true in index.md file frontmatter don't include any page related to this page collection in production
      if (postIndex?.data.draft && import.meta.env.PROD) {
        return [];
      }

      // Disable page generation if blog pagination is 0 or false
      if (!blogPerPage) {
        return [];
      }

      const totalPages = Math.ceil(posts.length / blogPerPage);

      for (let i = 1; i < totalPages; i++) {
        paths.push({
          params: {
            slug: (i + 1).toString(),
          },
        });
      }

      return paths.map((path) => ({
        params: {
          slug: path.params.slug,
          lang:
            lang.languageCode === defaultLanguage && !showDefaultLangInUrl
              ? undefined
              : lang.languageCode,
        },
        props: {
          postIndex,
          pagination: blogPerPage,
          blogCollection: posts,
        },
      }));
    }),
  );

  return paths.flat();
}

const { slug } = Astro.params;
const currentPage = slug && !isNaN(Number(slug)) ? Number(slug) : 1;
let { postIndex } = Astro.props;
---

<Base {...postIndex?.data}>
  <PageHeader content={postIndex?.data} />
  <BlogLayout
    contentList={{
      pagination: { enable: true, currentPage },
      options: { ...postIndex?.data.options },
    }}
    sidebar={{
      enable: true,
      sticky: true,
    }}
    pageType="list"
    content={{ ...postIndex, ...postIndex?.data }}
  />
</Base>
