---
/**
 * Example Usage

  <Tabs>
    <Tab name="Overview">
      #### How Can We Assist You?

      We offer personalized consultations to help you achieve your personal and professional goals. Choose a tab below to explore our services.

      - Personal Coaching
      - Career Counseling
      - Conflict Resolution
      - Life Advice
    </Tab>
  </Tabs>

 */
import { parseHTML } from "linkedom";
import { useTranslations } from "@/lib/utils/i18nUtils";

// Render all the slot content
const slotContent = await Astro.slots.render("default");

// Parse the rendered content
const { document } = parseHTML(slotContent);
const tabElements = Array.from(document.children) as Element[];
const t = await useTranslations(Astro.currentLocale as string);
---

<div class="border-border-dark flex flex-col">
  <nav
    class="inline-flex flex-wrap divide-x border-x border-inherit"
    aria-label={t("aria.tabs")}
    role="tablist">
    {
      tabElements.map((tab, index) => (
        <button
          type="button"
          class={`tab-button [&.active]:bg-primary w-fit flex-1 border-t border-inherit px-8 py-2.5 [&.active]:text-white ${index === 0 ? "active" : ""}`}
          id={`tab-${index}`}
          aria-controls={`panel-${index}`}
          role="tab"
          aria-selected={index === 0 ? "true" : "false"}
          data-hs-tab={`#panel-${index}`}>
          {(tab as Element).getAttribute("data-name") ||
            `${t("common.tab")} ${index + 1}`}
        </button>
      ))
    }
  </nav>

  <div class="border border-inherit bg-white p-4">
    {
      tabElements.map((tab, index) => (
        <div
          id={`panel-${index}`}
          class={`prose-styles tab-panel ${index === 0 ? "" : "hidden"}`}
          role="tabpanel"
          aria-labelledby={`tab-${index}`}
          set:html={(tab as Element).innerHTML}
        />
      ))
    }
  </div>
</div>
