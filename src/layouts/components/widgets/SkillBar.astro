---
// src/components/widgets/SkillBar.astro
const { label, value } = Astro.props;
---

<div class="mb-6">
  <div class="text-dark mb-2 flex justify-between font-bold">
    <span>{label}</span>
    <span>{value}%</span>
  </div>
  <div class="bg-theme-light h-2 w-full overflow-hidden rounded-full">
    <div
      class="bg-primary h-full transition-all duration-1000"
      style={`width: ${value}%`}>
    </div>
  </div>
</div>
