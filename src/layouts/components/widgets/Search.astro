---
import { getCollectionCTM } from "@/lib/contentParser.astro";
import { getEntryCTM } from "@/lib/contentParser.astro";
import { sortByDate } from "@/lib/utils/sortFunctions";
import bgOptimizedImage from "@/lib/utils/bgOptimizedImage";
import { slugifyyy } from "@/lib/utils/textConverter";
import { generateCategorySlugs } from "@/lib/taxonomyParser.astro";
import { getLocaleUrlCTM, useTranslations } from "@/lib/utils/i18nUtils.ts";
import Icons from "@/helpers/Icons.astro";
import extractSlug from "@/lib/utils/extractSlug";

interface Props {
  class: string;
}

const currentLocale = Astro.currentLocale;
import config from ".astro/config.generated.json";
const blogFolder = config.settings.blogFolder as "blog";

let posts = await getCollectionCTM(blogFolder as "blog", currentLocale);
posts = await processPosts(posts);

const postJson = sortByDate(posts).map((item) => {
  return {
    title: item.data.title,
    slug: getLocaleUrlCTM(extractSlug(item), currentLocale, blogFolder),
    date: item.data.date,
    author: item.data.author,
    authorImage: item.data.authorImage,
    image: item.data.image,
    description: item.data.description,
    categories: generateCategorySlugs(
      item.data.categories,
      currentLocale as string,
      blogFolder,
    ),
  };
});

async function processPosts(sortedPosts: any) {
  sortedPosts = await Promise.all(
    sortedPosts.map(async (post: any) => {
      const authorEntry = await getEntryCTM(
        "author",
        slugifyyy(post.data.author || ""),
        currentLocale,
      );

      return {
        ...post,
        data: {
          ...post.data,
          image: post.data.image && (await bgOptimizedImage(post.data.image)),
          author: authorEntry?.data.title,
          authorImage:
            authorEntry?.data.image &&
            (await bgOptimizedImage(authorEntry?.data.image)),
        },
      };
    }),
  );

  return sortedPosts;
}

const baseURL = Astro.url.origin;
const t = await useTranslations(Astro.currentLocale as string);
const learnMoreI18n = t("common.learnMoreAbout");
const btnLabelReadMoreI18n = t("common.readMore");
const blogIndexUrl = getLocaleUrlCTM("", currentLocale, blogFolder);

const notFoundImage = await bgOptimizedImage("/images/404.svg");
---

<div class="border-border-light bg-theme-light rounded-2xl border p-7">
  <h2 class="text-h5-sm md:text-h5 mb-5">{t("widgets.searchTitle")}</h2>
  <form method="post" class="relative" id="search">
    <input
      name="search"
      type="text"
      placeholder={t("widgets.searchInputPlaceholder")}
      class="form-input w-full rounded-md border-none! bg-white! p-5! pe-16! placeholder:opacity-60!"
    />
    <button
      type="submit"
      class="has-icon-moving-animation text-primary absolute inset-y-0 inset-e-0 flex w-14 items-center justify-center bg-white">
      <span class="sr-only">{t("widgets.searchTitle")}</span>
      <Icons class="size-5" icon="Search" />
    </button>
  </form>
</div>

<script
  is:inline
  type="application/json"
  id="blog-search-data"
  set:html={JSON.stringify({
    posts: postJson,
    baseURL,
    notFoundImage,
    blogFolder,
    blogIndexUrl,
    learnMoreI18n,
    btnLabelReadMoreI18n,
    trailingSlash: config.site.trailingSlash,
  }).replace(/</g, "\\u003c")}
/>

<script>
  // @ts-nocheck
  // Config + post index are delivered as inert JSON above and consumed by this
  // bundled (deferred) module. Keeping the search logic out of a render-blocking
  // inline script prevents the first paint from happening before the search box
  // is styled, which previously caused a layout shift on blog pages.
  const searchDataEl = document.getElementById("blog-search-data");
  const searchConfig = searchDataEl
    ? JSON.parse(searchDataEl.textContent || "{}")
    : {};
  const {
    baseURL,
    notFoundImage,
    blogFolder,
    blogIndexUrl,
    learnMoreI18n,
    btnLabelReadMoreI18n,
    trailingSlash,
  } = searchConfig;
  const postJson = searchConfig.posts || [];

  const shouldHaveTrailingSlash = trailingSlash;

  const trailingSlashCheckerInline = (url) => {
    // Separate the URL path from the fragment (if any)
    const [urlPath, fragment] = url.split("#");

    // Determine if we need to add or remove a trailing slash
    const hasTrailingSlash = urlPath.endsWith("/");

    // Adjust the URL path based on the trailing slash rule
    const adjustedPath = shouldHaveTrailingSlash
      ? hasTrailingSlash
        ? urlPath
        : `${urlPath}/`
      : hasTrailingSlash
        ? urlPath.slice(0, -1)
        : urlPath;

    // Reattach the fragment if it exists
    const fullURL = fragment ? `${adjustedPath}#${fragment}` : adjustedPath;

    return fullURL;
  };

  const searchForm = document.querySelector("#search");
  let searchResults = document.querySelector(".blog-search-results");
  let prevResults = "";

  const escapeHTML = (value) =>
    value.replace(
      /[&<>"']/g,
      (char) =>
        ({
          "&": "&amp;",
          "<": "&lt;",
          ">": "&gt;",
          '"': "&quot;",
          "'": "&#039;",
        })[char],
    );

  const getSearchContext = () => {
    searchResults = document.querySelector(".blog-search-results");
    return {
      searchResults,
      searchOnlyContent: searchResults?.closest("[data-search-only-content]"),
      currentPageContent: document.querySelector(
        ".current-page-content, .single-page-content",
      ),
      pagination: document.querySelector("#pagination"),
    };
  };

  const setSearchMode = (active) => {
    const { searchResults, searchOnlyContent, currentPageContent, pagination } =
      getSearchContext();

    if (searchOnlyContent) {
      searchOnlyContent.classList.toggle("hidden", !active);
      searchResults?.classList.toggle("hidden", !active);
      currentPageContent?.classList.toggle("hidden", active);
    } else {
      searchResults?.classList.remove("hidden");
    }

    pagination?.classList.toggle("hidden", active);
  };

  const redirectToBlogSearch = (searchTerm) => {
    const target = new URL(blogIndexUrl, window.location.origin);
    if (searchTerm) target.searchParams.set("search", searchTerm);
    window.location.href = `${target.pathname}${target.search}${target.hash}`;
  };

  const runSearch = (searchTerm) => {
    const { searchResults } = getSearchContext();
    const normalizedSearchTerm = searchTerm.trim().toLowerCase();

    if (!searchResults) {
      redirectToBlogSearch(searchTerm.trim());
      return;
    }

    const filteredPosts = postJson.filter((post) => {
      return post.title?.toLowerCase().includes(normalizedSearchTerm);
    });

    if (normalizedSearchTerm === "") {
      searchResults.innerHTML = prevResults;
      setSearchMode(false);
      return;
    }

    searchResults.innerHTML = "";
    setSearchMode(true);

    // If no posts found, display 404 image with text
    if (filteredPosts.length === 0) {
      const notFoundHTML = `
            <div class="text-center space-y-10 w-full col-span-2 mt-8 md:mt-16">
              <img class="w-96 mx-auto" src=${notFoundImage} alt="404" />
              <p class="text-h6">
                No Posts Found For <span class="text-primary">"${escapeHTML(searchTerm.trim())}"</span>
              </p>
            </div>
            `;
      searchResults.innerHTML = notFoundHTML;
      return;
    }

    filteredPosts.forEach((post) => {
      renderBlogPost(post);
    });
  };

  document.addEventListener("DOMContentLoaded", () => {
    const { searchResults } = getSearchContext();
    if (searchResults) prevResults = searchResults.innerHTML;

    const initialSearchTerm = new URLSearchParams(window.location.search).get(
      "search",
    );
    if (!initialSearchTerm || !searchForm) return;

    const searchInput = searchForm.querySelector("[name='search']");
    if (searchInput) searchInput.value = initialSearchTerm;
    runSearch(initialSearchTerm);
  });

  searchForm?.addEventListener("submit", (e) => {
    e.preventDefault();
    runSearch(e.target[0].value);
  });

  const updatePostImage = (postCard, post) => {
    const image = postCard.querySelector("img");
    if (!image) return;

    image
      .closest("picture")
      ?.querySelectorAll("source")
      .forEach((source) => {
        source.remove();
      });

    image.removeAttribute("srcset");
    image.removeAttribute("sizes");
    image.setAttribute("src", post.image || "");
    image.setAttribute("alt", post.title || "");
  };

  // Function to render a blog post
  function renderBlogPost(post) {
    // Function to format a date in "17 Jun, 2222" format
    const dateFormat = (date, pattern = "dd MMM, yyyy") => {
      const dateObj = new Date(date);

      if (pattern === "dd MMM, yyyy") {
        const formatter = new Intl.DateTimeFormat("en-US", {
          day: "2-digit",
          month: "short",
          year: "numeric",
        });
        return formatter.format(dateObj);
      }

      throw new Error(`Unsupported pattern: ${pattern}`);
    };

    // Clone an existing blog post node from the current layout as a template
    const blogPostTemplate = document.querySelector(".template-post-search");
    if (!blogPostTemplate) return;

    const newPost = blogPostTemplate.cloneNode(true);

    // Update its content dynamically
    newPost.classList.remove("template-post-search");
    newPost.classList.remove("hidden");
    updatePostImage(newPost, post);
    newPost.querySelectorAll("a[data-post-link]").forEach((link) => {
      link?.setAttribute("href", post.slug || "");
    });
    newPost
      .querySelector("a[href]")
      ?.setAttribute("title", `${learnMoreI18n} ${post.title}`);

    const titleEl = newPost.querySelector("h2, h3, h4");
    if (titleEl) titleEl.textContent = post.title;

    // Update the date
    const dateEl = newPost.querySelector("[data-post-date]");
    if (dateEl) dateEl.textContent = dateFormat(post.date);

    // Replace categories if needed
    const categoriesWrapper = newPost.querySelector(".post-categories");
    if (categoriesWrapper && post.categories) {
      categoriesWrapper.innerHTML = post.categories
        .map(
          (category) =>
            `<a href="${trailingSlashCheckerInline(`/${blogFolder}/category/${category.slug}`)}">${category.name}</a>`,
        )
        .join(" • ");
    }

    searchResults.appendChild(newPost);
  }
</script>
