---
import OptimizedImage from "@/components/utilities/OptimizedImage.astro";
import { getLocaleUrlCTM } from "@/lib/utils/i18nUtils";
import { slugifyyy } from "@/lib/utils/textConverter";
import type { SocialLink } from "@/types";

const baseURL = process.env.SITE;

interface BaseProps {
  class?: string;
  list: SocialLink[];
  size?: "sm" | "md" | "lg";
  buttonSize?: "md" | "lg";
  activeLabel?: string;
  linkType?: "share" | "follow";
  [key: string]: any;
}

interface ShareProps extends BaseProps {
  slug: string;
  linkType?: "share";
  title?: string;
  description?: string;
  disabled?: string[];
}

interface FollowProps extends BaseProps {
  linkType?: "follow";
}

type Props = ShareProps | FollowProps;

let {
  list,
  size = "md",
  buttonSize = "lg",
  activeLabel,
  title,
  slug,
  disabled,
  linkType = "follow",
  description,
  class: className,
  ...rest
} = Astro.props as Props;

slug = slug ? getLocaleUrlCTM(slug, Astro.currentLocale) : "";

const shareLinks: { [key: string]: string } = {
  facebook: `https://www.facebook.com/sharer/sharer.php?u=${slug}`,
  twitter: `https://twitter.com/intent/tweet/?text=${title || ""}&amp;url=${slug}`,
  linkedin: `https://www.linkedin.com/shareArticle?mini=true&url=${slug}&title=${title || ""}&summary=${slugifyyy(description) || ""}&source=${baseURL}`,
  pinterest: `https://pinterest.com/pin/create/button/?url=${slug}&media=&description=${slugifyyy(description) || ""}`,
};

// Only render links that resolve to a real URL so every anchor stays crawlable.
list =
  linkType === "share"
    ? list.filter((social) => shareLinks[social.label])
    : list.filter((social) => social.url);

if (disabled) {
  list = list.filter((social) => !disabled.includes(social.label));
}

// Shared social links for footer, contact, and post sharing widgets.
---

{
  list && list[0] && (
    <ul
      class:list={["flex flex-wrap items-center", className || "gap-4"]}
      {...rest}>
      {list.map((social) => (
        <li>
          <a
            aria-label={social.label}
            href={linkType === "share" ? shareLinks[social.label] : social.url}
            target="_blank"
            rel="noopener noreferrer nofollow"
            class:list={[
              "group text-dark hover:bg-primary bg-border-light relative flex items-center justify-center rounded-lg transition duration-300 hover:text-white",
              buttonSize === "md" ? "size-11 rounded-md" : "size-12",
              activeLabel === social.label && "bg-primary text-white",
            ]}>
            <span class="sr-only">{social.label}</span>
            {social.icon && (
              <OptimizedImage
                inlineSvg={true}
                src={social.icon}
                class:list={[
                  "text-inherit",
                  {
                    "h-4 w-4": size === "sm",
                    "h-5 w-5": size === "md",
                    "h-6 w-6": size === "lg",
                  },
                ]}
                alt={social.label}
              />
            )}
          </a>
        </li>
      ))}
    </ul>
  )
}
