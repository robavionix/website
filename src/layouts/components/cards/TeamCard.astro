---
import type { CollectionEntry } from "astro:content";
import { markdownify, toSentenceCase } from "@/lib/utils/textConverter";
import { getLocaleUrlCTM, useTranslations } from "@/lib/utils/i18nUtils.ts";
import OptimizedImage from "@/components/utilities/OptimizedImage.astro";
import extractSlug from "@/lib/utils/extractSlug";

interface Props {
  content: CollectionEntry<"team">;
  class?: string;
}

const { content, class: className, ...rest } = Astro.props;
const { title, image, profession, social } = content.data;

const t = await useTranslations(Astro.currentLocale as string);
const slug = getLocaleUrlCTM(
  extractSlug(content),
  Astro.currentLocale,
  content.collection,
);

const socialPriority = ["linkedin", "twitter", "instagram", "facebook"];
const getSocialKey = (item: { label?: string; icon?: string }) => {
  const value = `${item.label || ""} ${item.icon || ""}`.toLowerCase();

  if (value.includes("linkedin")) return "linkedin";
  if (value.includes("twitter") || value.includes("x")) return "twitter";
  if (value.includes("instagram")) return "instagram";
  if (value.includes("facebook")) return "facebook";

  return item.label?.toLowerCase() || "social";
};
const getSocialPriority = (item: { label?: string; icon?: string }) => {
  const priority = socialPriority.indexOf(getSocialKey(item));
  return priority === -1 ? socialPriority.length : priority;
};

const visibleSocials = [...(social || [])]
  .filter((item) => item.enable && item.url)
  .sort((a, b) => getSocialPriority(a) - getSocialPriority(b))
  .slice(0, 3)
  .map((item) => ({ ...item, key: getSocialKey(item) }));
---

{
  image && (
    <article
      data-cursor-label={t("common.viewDetails")}
      data-cursor-type="link"
      class:list={[
        "group relative overflow-hidden rounded-2xl bg-white",
        className,
      ]}
      {...rest}>
      <div class="team-card-image-bg aspect-team-card-image relative overflow-hidden rounded-t-2xl">
        <OptimizedImage
          src={image}
          alt={title}
          class="pointer-events-none h-full w-full object-cover transition duration-500 group-hover:scale-105"
        />

        {visibleSocials.length > 0 && (
          <ul
            class="absolute top-10 left-10 z-30 flex translate-y-2 flex-col gap-2 opacity-0 transition duration-300 group-hover:translate-y-0 group-hover:opacity-100"
            aria-label={`${title} social links`}>
            {visibleSocials.map((item) => (
              <li>
                <a
                  href={item.url}
                  target="_blank"
                  rel="noopener noreferrer nofollow"
                  data-cursor-label={item.label}
                  data-cursor-type="link"
                  aria-label={`${title} ${item.label}`}
                  class="text-dark hover:bg-primary flex size-11 items-center justify-center rounded-md bg-white shadow-sm transition duration-300 hover:text-white">
                  {item.key === "linkedin" ? (
                    <svg
                      class="size-5"
                      viewBox="0 0 24 24"
                      fill="currentColor"
                      aria-hidden="true">
                      <path d="M4.98 3.5C4.98 4.88 3.87 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1s2.48 1.12 2.48 2.5ZM.28 8.25h4.44V23H.28V8.25Zm7.22 0h4.25v2.02h.06c.59-1.12 2.04-2.3 4.2-2.3 4.49 0 5.32 2.96 5.32 6.8V23h-4.43v-7.3c0-1.74-.03-3.98-2.43-3.98-2.43 0-2.8 1.9-2.8 3.86V23H7.5V8.25Z" />
                    </svg>
                  ) : item.key === "twitter" ? (
                    <svg
                      class="size-5"
                      viewBox="0 0 24 24"
                      fill="currentColor"
                      aria-hidden="true">
                      <path d="M18.24 2.25h3.31l-7.23 8.26 8.5 11.24h-6.65l-5.2-6.8-5.96 6.8H1.7l7.74-8.84L1.3 2.25h6.82l4.7 6.22 5.42-6.22Zm-1.16 17.52h1.84L7.12 4.13H5.15l11.93 15.64Z" />
                    </svg>
                  ) : item.key === "instagram" ? (
                    <svg
                      class="size-5"
                      viewBox="0 0 24 24"
                      fill="none"
                      aria-hidden="true">
                      <rect
                        x="3"
                        y="3"
                        width="18"
                        height="18"
                        rx="5"
                        stroke="currentColor"
                        stroke-width="2"
                      />
                      <circle
                        cx="12"
                        cy="12"
                        r="4"
                        stroke="currentColor"
                        stroke-width="2"
                      />
                      <circle cx="17.5" cy="6.5" r="1.2" fill="currentColor" />
                    </svg>
                  ) : (
                    <span class="text-sm font-semibold" aria-hidden="true">
                      {item.label?.slice(0, 2)}
                    </span>
                  )}
                </a>
              </li>
            ))}
          </ul>
        )}
      </div>

      <div class="px-7 pt-5 pb-5">
        {title && <h3 class="text-xl" set:html={markdownify(title)} />}
        {profession && (
          <p
            class="text-text-default mt-1 text-base leading-7"
            set:html={markdownify(profession)}
          />
        )}
      </div>
      <a
        title={toSentenceCase(t("common.learnMoreAbout") + " " + title)}
        class="absolute inset-0 z-20"
        href={slug}
      />
    </article>
  )
}

<style>
  .team-card-image-bg {
    background:
      radial-gradient(
        circle at 76% 18%,
        rgba(10, 102, 194, 0.16),
        transparent 30%
      ),
      radial-gradient(
        circle at 18% 82%,
        rgba(10, 102, 194, 0.1),
        transparent 28%
      ),
      linear-gradient(145deg, #f8fbfd 0%, #edf4f8 48%, #dfeaf1 100%);
  }

  .team-card-image-bg::before {
    content: "";
    position: absolute;
    inset: 22px 22px 0;
    border-radius: 24px 24px 0 0;
    background: rgba(255, 255, 255, 0.58);
    box-shadow: 0 18px 44px rgba(9, 30, 66, 0.1);
  }

  .team-card-image-bg img {
    position: relative;
    z-index: 1;
  }
</style>
