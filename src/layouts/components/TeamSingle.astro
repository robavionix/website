---
import type { InferEntrySchema } from "astro:content";
import { markdownify } from "@/lib/utils/textConverter";
import { shortcodes } from "@/lib/shortcodes";
import OptimizedImage from "./utilities/OptimizedImage.astro";
import { render } from "astro:content";

const { data } = Astro.props.content;
const { title, image, social, profession, email, phone } =
  data as InferEntrySchema<"team">;

const { Content } = await render(Astro.props.content);

const socialPriority = ["facebook", "linkedin", "twitter", "instagram"];
const getSocialKey = (item: { label?: string; icon?: string }) => {
  const value = `${item.label || ""} ${item.icon || ""}`.toLowerCase();

  if (value.includes("facebook")) return "facebook";
  if (value.includes("linkedin")) return "linkedin";
  if (value.includes("twitter") || value.includes("x")) return "twitter";
  if (value.includes("instagram")) return "instagram";

  return item.label?.toLowerCase() || "social";
};
const getSocialPriority = (item: { label?: string; icon?: string }) => {
  const priority = socialPriority.indexOf(getSocialKey(item));
  return priority === -1 ? socialPriority.length : priority;
};

const visibleSocials = [...(social || [])]
  .filter((item) => item.enable && item.url)
  .sort((a, b) => getSocialPriority(a) - getSocialPriority(b))
  .slice(0, 4)
  .map((item) => ({ ...item, key: getSocialKey(item) }));
---

<section>
  <div class="container">
    <div
      class="team-single-layout mx-auto grid w-full grid-cols-1 items-center gap-y-10 lg:grid-cols-2">
      {
        image && (
          <div class="team-single-image relative overflow-hidden rounded-2xl">
            <OptimizedImage
              src={image}
              alt={title || "team member"}
              width={600}
              height={700}
              class="relative z-1 h-full w-full object-cover"
            />
          </div>
        )
      }

      <div class="team-single-content">
        <div class="space-y-2">
          {
            title && (
              <h1
                class="team-single-title md:text-h2 text-h3-sm"
                set:html={title}
              />
            )
          }
          {
            profession && (
              <p
                class="team-single-profession font-semibold"
                set:html={markdownify(profession)}
              />
            )
          }
        </div>

        <div class="team-single-bio prose-styles max-w-none">
          <Content components={shortcodes} />
        </div>

        <div class="team-single-contact space-y-3">
          {
            phone && (
              <div class="team-single-contact-item">
                <svg
                  class="size-5"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  aria-hidden="true">
                  <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.3-.3.73-.39 1.12-.26 1.23.41 2.55.63 3.91.63.59 0 1.06.47 1.06 1.06v3.49c0 .59-.47 1.06-1.06 1.06C10.46 21.66 2.34 13.54 2.34 3.56c0-.59.47-1.06 1.06-1.06h3.5c.59 0 1.06.47 1.06 1.06 0 1.36.22 2.68.63 3.91.12.39.03.82-.27 1.12l-2.2 2.2Z" />
                </svg>
                <span set:html={markdownify(phone)} />
              </div>
            )
          }

          {
            email && (
              <div class="team-single-contact-item">
                <svg
                  class="size-5"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  aria-hidden="true">
                  <path d="M3.5 5h17c.83 0 1.5.67 1.5 1.5v11c0 .83-.67 1.5-1.5 1.5h-17c-.83 0-1.5-.67-1.5-1.5v-11C2 5.67 2.67 5 3.5 5Zm.5 3.08v8.42c0 .28.22.5.5.5h15c.28 0 .5-.22.5-.5V8.08l-7.46 5.02c-.33.22-.76.22-1.09 0L4 8.08Zm.9-1.08 7.1 4.78L19.1 7H4.9Z" />
                </svg>
                <span set:html={markdownify(email)} />
              </div>
            )
          }
        </div>

        {
          visibleSocials.length > 0 && (
            <ul class="team-single-social" aria-label={`${title} social links`}>
              {visibleSocials.map((item) => (
                <li>
                  <a
                    href={item.url}
                    target="_blank"
                    rel="noopener noreferrer nofollow"
                    aria-label={`${title} ${item.label}`}
                    class="team-single-social-link">
                    {item.key === "facebook" ? (
                      <svg
                        class="size-5"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        aria-hidden="true">
                        <path d="M14 8.5V6.75c0-.48.39-.88.88-.88H17V2.25h-3.02c-3.12 0-4.8 1.86-4.8 4.55v1.7H6v3.94h3.18V22H14v-9.56h3.18l.5-3.94H14Z" />
                      </svg>
                    ) : item.key === "linkedin" ? (
                      <svg
                        class="size-5"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        aria-hidden="true">
                        <path d="M4.98 3.5C4.98 4.88 3.87 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1s2.48 1.12 2.48 2.5ZM.28 8.25h4.44V23H.28V8.25Zm7.22 0h4.25v2.02h.06c.59-1.12 2.04-2.3 4.2-2.3 4.49 0 5.32 2.96 5.32 6.8V23h-4.43v-7.3c0-1.74-.03-3.98-2.43-3.98-2.43 0-2.8 1.9-2.8 3.86V23H7.5V8.25Z" />
                      </svg>
                    ) : item.key === "twitter" ? (
                      <svg
                        class="size-5"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        aria-hidden="true">
                        <path d="M18.24 2.25h3.31l-7.23 8.26 8.5 11.24h-6.65l-5.2-6.8-5.96 6.8H1.7l7.74-8.84L1.3 2.25h6.82l4.7 6.22 5.42-6.22Zm-1.16 17.52h1.84L7.12 4.13H5.15l11.93 15.64Z" />
                      </svg>
                    ) : item.key === "instagram" ? (
                      <svg
                        class="size-5"
                        viewBox="0 0 24 24"
                        fill="none"
                        aria-hidden="true">
                        <rect
                          x="3"
                          y="3"
                          width="18"
                          height="18"
                          rx="5"
                          stroke="currentColor"
                          stroke-width="2"
                        />
                        <circle
                          cx="12"
                          cy="12"
                          r="4"
                          stroke="currentColor"
                          stroke-width="2"
                        />
                        <circle
                          cx="17.5"
                          cy="6.5"
                          r="1.2"
                          fill="currentColor"
                        />
                      </svg>
                    ) : (
                      <span class="text-sm font-semibold" aria-hidden="true">
                        {item.label?.slice(0, 2)}
                      </span>
                    )}
                  </a>
                </li>
              ))}
            </ul>
          )
        }
      </div>
    </div>
  </div>
</section>

<style>
  .team-single-layout {
    max-width: 1272px;
    gap: 48px;
  }

  .team-single-image {
    min-height: 420px;
    background:
      radial-gradient(
        circle at 76% 18%,
        rgba(10, 102, 194, 0.16),
        transparent 30%
      ),
      radial-gradient(
        circle at 18% 82%,
        rgba(10, 102, 194, 0.1),
        transparent 28%
      ),
      linear-gradient(145deg, #f8fbfd 0%, #edf4f8 48%, #dfeaf1 100%);
  }

  .team-single-image::before {
    content: "";
    position: absolute;
    inset: 30px 30px 0;
    border-radius: 24px 24px 0 0;
    background: rgba(255, 255, 255, 0.58);
    box-shadow: 0 18px 44px rgba(9, 30, 66, 0.1);
  }

  .team-single-content {
    color: #0a165e;
  }

  .team-single-title {
    color: #0a165e;
  }

  .team-single-profession {
    color: #2b4dff;
    font-size: 20px;
    line-height: 34px;
  }

  .team-single-bio {
    margin-top: 26px;
    color: #585b6f;
    font-size: 16px;
    line-height: 30px;
  }

  .team-single-contact {
    margin-top: 28px;
  }

  .team-single-contact-item {
    display: flex;
    align-items: center;
    gap: 10px;
    color: #0a165e;
    font-size: 16px;
    line-height: 30px;
  }

  .team-single-social {
    display: flex;
    gap: 8px;
    margin-top: 22px;
  }

  .team-single-social-link {
    display: flex;
    width: 44px;
    height: 44px;
    align-items: center;
    justify-content: center;
    border-radius: 6px;
    background: #e2e3ec;
    color: #0a165e;
    transition:
      background-color 0.3s ease,
      color 0.3s ease;
  }

  .team-single-social-link:hover,
  .team-single-social-link.is-active {
    background: #2b4dff;
    color: #ffffff;
  }

  @media (min-width: 1024px) {
    .team-single-layout {
      grid-template-columns: minmax(420px, 526px) minmax(0, 626px);
      gap: 120px;
    }

    .team-single-image {
      min-height: 558px;
    }
  }
</style>
