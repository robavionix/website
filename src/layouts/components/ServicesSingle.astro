---
import Icons from "@/helpers/Icons.astro";
import { shortcodes } from "@/lib/shortcodes";
import { getCollectionCTM } from "@/lib/contentParser.astro";
import extractSlug from "@/lib/utils/extractSlug";
import { getLocaleUrlCTM, useTranslations } from "@/lib/utils/i18nUtils.ts";
import type { CollectionEntry } from "astro:content";
import { render } from "astro:content";
import OptimizedImage from "./utilities/OptimizedImage.astro";
import CallToActionWidget from "./widgets/CallToActionWidget.astro";

interface Props {
  content: CollectionEntry<"curriculum">;
}

const { content } = Astro.props;
const {
  data: { title, image, experiments },
} = content;

const services = await getCollectionCTM("curriculum", Astro.currentLocale);
const { Content } = await render(content);
const t = await useTranslations(Astro.currentLocale as string);

// Most levels' experiments apply the same way regardless of airframe, so
// they render as one flat numbered list. A level whose experiments carry a
// mix of `platform` tags (e.g. fixed-wing vs. quadrotor steps that genuinely
// differ in method, not just labelling) instead renders as separate
// numbered tracks, one per platform, each restarting at 01.
const platformLabels: Record<string, string> = {
  "fixed-wing": t("curriculum.platformFixedWing"),
  quadrotor: t("curriculum.platformQuadrotor"),
};

const taggedPlatforms = new Set(
  (experiments ?? []).map((item) => item.platform).filter(Boolean),
);

const experimentGroups =
  taggedPlatforms.size > 1
    ? (["fixed-wing", "quadrotor"] as const)
        .map((platformKey) => ({
          label: platformLabels[platformKey],
          items: (experiments ?? []).filter(
            (item) => item.platform === platformKey,
          ),
        }))
        .filter((group) => group.items.length > 0)
    : [{ label: null, items: experiments ?? [] }];
---

<section class="section-spacing-vertical">
  <div class="container">
    <div class="grid gap-10 lg:grid-cols-12 xl:gap-12">
      <article class="lg:col-span-8">
        {
          image && (
            <OptimizedImage
              src={image}
              width={856}
              height={570}
              alt={title}
              data-image-lightbox
              class="h-80 w-full rounded-2xl object-cover md:h-112.5 xl:h-142.5"
            />
          )
        }

        {
          Content && (
            <div class="service-single-content prose-styles content has-video-modal mt-10 md:mt-12">
              <Content components={shortcodes} />
            </div>
          )
        }

        {
          experiments && experiments.length > 0 && (
            <div class="mt-12 space-y-10 md:mt-16">
              <h2>{t("curriculum.experimentsHeading")}</h2>

              {experimentGroups.map((group) => (
                <div class="space-y-6">
                  {group.label && (
                    <h3 class="text-primary text-base tracking-wide uppercase">
                      {group.label}
                    </h3>
                  )}

                  <div class="space-y-6">
                    {group.items.map((item, index) => (
                      <div
                        class="flex gap-5"
                        data-scroll-reveal="fade-up"
                        data-scroll-reveal-delay={index * 100}>
                        <span class="bg-primary flex size-10 flex-none items-center justify-center rounded-full text-sm leading-none font-semibold text-white">
                          {String(index + 1).padStart(2, "0")}
                        </span>

                        <div class="space-y-2">
                          {group.label ? (
                            <h4 class="text-dark text-lg">{item.title}</h4>
                          ) : (
                            <h3 class="text-dark text-lg">{item.title}</h3>
                          )}
                          {item.description && (
                            <p class="text-sm">{item.description}</p>
                          )}
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          )
        }
      </article>

      <aside class="lg:col-span-4">
        <div class="sticky-sidebar space-y-9 lg:sticky">
          <nav aria-label={t("aria.curriculum")}>
            <ul class="space-y-2.5">
              {
                services.map((service) => {
                  const isActive =
                    service.filePath === content.filePath ||
                    service.id === content.id;

                  return (
                    <li>
                      <a
                        href={getLocaleUrlCTM(
                          extractSlug(service),
                          Astro.currentLocale,
                          "curriculum",
                        )}
                        aria-current={isActive ? "page" : undefined}
                        class:list={[
                          "flex items-center justify-between gap-4 rounded-md px-6 py-4.5 text-sm leading-6 font-semibold transition duration-300 md:text-base",
                          isActive
                            ? "bg-primary text-white"
                            : "bg-light/70 text-dark hover:bg-primary hover:text-white",
                        ]}>
                        <span>{service.data.title}</span>
                        <Icons
                          icon="ArrowUpRight"
                          class="size-5 shrink-0"
                          stroke-width="2"
                        />
                      </a>
                    </li>
                  );
                })
              }
            </ul>
          </nav>

          <CallToActionWidget />
        </div>
      </aside>
    </div>
  </div>

  <script>
    import { stickySidebar } from "@/plugins/sticky-sidebar.js";

    const sidebar = document.querySelector(".sticky-sidebar");
    if (sidebar) {
      new stickySidebar(sidebar, {
        offsetTop: 132,
        offsetBottom: 20,
      });
    }
  </script>
</section>
