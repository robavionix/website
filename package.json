    "@realfavicongenerator/image-adapter-node": "^0.8.3",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "^7.0.2",
    "astro-font": "^1.1.0",
    "gray-matter": "^4.0.3",
    "ignore": "^7.0.5",
    "linkedom": "^0.18.12",
    "prettier": "^3.8.4",
